// Prisma schema — local-first SQLite. Stores optional user accounts and the
// history of completed games. Live room/game state stays in server memory.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection for the app runtime (Neon "-pooler" host / Vercel serverless).
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection used by `prisma migrate`. On Neon this is the
  // host WITHOUT "-pooler". Locally it can equal DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

model User {
  id           String              @id @default(cuid())
  username     String              @unique
  passwordHash String
  displayName  String
  createdAt    DateTime            @default(now())
  participations GameParticipant[]
}

model GameRecord {
  id           String              @id @default(cuid())
  roomCode     String
  variant      String              @default("classic")
  startingTeam String
  winner       String?
  winReason    String?
  startedAt    DateTime
  finishedAt   DateTime            @default(now())
  participants GameParticipant[]

  @@index([roomCode])
}

model FriendRequest {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  status     String   @default("pending") // pending | accepted | declined
  createdAt  DateTime @default(now())

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@index([fromUserId])
}

model Friendship {
  id        String   @id @default(cuid())
  // Normalised so a friendship is stored once: userAId < userBId.
  userAId   String
  userBId   String
  createdAt DateTime @default(now())

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model DirectMessage {
  id          String    @id @default(cuid())
  fromUserId  String
  toUserId    String
  body        String
  createdAt   DateTime  @default(now())
  deliveredAt DateTime?
  seenAt      DateTime?

  @@index([fromUserId, toUserId])
  @@index([toUserId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String // recipient
  type      String // friend_request | friend_accepted | game_invite | message
  actorId   String?
  actorName String?
  roomCode  String?
  text      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model GameParticipant {
  id           String     @id @default(cuid())
  gameRecord   GameRecord @relation(fields: [gameRecordId], references: [id], onDelete: Cascade)
  gameRecordId String
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId       String?
  name         String
  team         String?
  role         String
  won          Boolean    @default(false)

  @@index([gameRecordId])
  @@index([userId])
}
