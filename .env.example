# Copy to .env and adjust. Local combined dev (npm run dev) uses these.

# HTTP + WebSocket server port (combined local server).
PORT=3000

# Postgres connection strings.
# Local: start `docker compose up -d` then use the lines below (both the same).
# Production (Neon): DATABASE_URL = pooled ("-pooler" host); DIRECT_URL = direct
# (host without "-pooler"), used only by `prisma migrate`. Include ?sslmode=require.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/codenames?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/codenames?schema=public"

# Secret used to sign auth JWTs. MUST be identical on the web app and the
# realtime server in a split deployment. Use a long random string in production.
JWT_SECRET="change-me-in-production-please-use-a-long-random-string"

# Access-token lifetime.
JWT_EXPIRES_IN="7d"

# --- Split deployment only (Next.js on Vercel + standalone realtime server) ---

# Browser -> realtime server URL. Baked into the client at BUILD time, so set it
# in the web host's env before building. Leave EMPTY for local combined dev.
# Example: https://codenames-realtime.onrender.com
NEXT_PUBLIC_SOCKET_URL=

# Realtime server CORS allow-list (comma-separated origins of the deployed UI).
# Set on the realtime server. Example: https://codenames.vercel.app
CLIENT_ORIGIN=
